# large or sensitive source assets belong in Storage, not Git
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.zip
*.7z
*.tar
*.tar.gz
*.heic
*.tif
*.tiff
*.mp4
*.mov
*.m4a
*.wav

# keep schema and minimal seed versioned
!supabase/migrations/
!supabase/migrations/*.sql
!supabase/seed.sql
